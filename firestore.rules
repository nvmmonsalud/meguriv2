rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(playerId) {
      return signedIn() && request.auth.uid == playerId;
    }

    match /players/{playerId} {
      allow create, read, update, delete: if owns(playerId);

      match /passport/{postcardId} {
        allow create, read, update, delete: if owns(playerId);
      }
    }

    match /parties/{partyId} {
      allow create: if signedIn()
        && request.resource.data.leaderId == request.auth.uid
        && request.resource.data.members is list;
      allow read: if signedIn();
      allow update, delete: if signedIn() && resource.data.leaderId == request.auth.uid;
    }
  }
}
