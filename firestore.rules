rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated (or just allow any visitor for demo/anon play)
    function isAuthenticated() {
      return true; // We allow simple client-side mock registration and ID generation for smooth onboarding in the iframe
    }

    // Rules for players
    match /players/{playerId} {
      allow read, write: if true;
      
      // Passport items
      match /passport/{postcardId} {
        allow read, write: if true;
      }
    }

    // Rules for parties
    match /parties/{partyId} {
      allow read, write: if true;
    }
  }
}
