# Gemini server-side AI. Leave unset for fallback-demo mode.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public app URL after deployment. Used by host platforms and future OAuth/share links.
APP_URL="http://localhost:3000"

# Demo controls. Use ?demo=true for a one-off judge flow; set these only for always-on demo deploys.
DEMO_MODE="false"
VITE_DEMO_MODE="false"

# Firebase client config. Leave unset for local/demo fallback state; set all values
# for live Firebase Auth + Firestore persistence.
VITE_FIREBASE_API_KEY="MY_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
VITE_FIREBASE_AUTH_DOMAIN="MY_FIREBASE_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET="MY_FIREBASE_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_FIREBASE_MESSAGING_SENDER_ID"
VITE_FIRESTORE_DATABASE_ID="(default)"
