rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsPlayer(playerId) {
      return signedIn() && request.auth.uid == playerId;
    }

    match /players/{playerId} {
      allow create: if ownsPlayer(playerId)
        && request.resource.data.id == playerId;
      allow read, update, delete: if ownsPlayer(playerId)
        && (!('id' in request.resource.data) || request.resource.data.id == playerId);

      match /passport/{postcardId} {
        allow read, write: if ownsPlayer(playerId);
      }
    }

    match /parties/{partyId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.leaderId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.leaderId == request.auth.uid;
    }
  }
}
